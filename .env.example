# PostgreSQL
POSTGRES_DB=contentfarm
POSTGRES_USER=contentfarm
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://contentfarm:change_me_postgres@postgres:5432/contentfarm

# Redis
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379
REDIS_URL=redis://:change_me_redis@redis:6379/0

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1
OLLAMA_KEEP_ALIVE=5m

# Telegram Bot API
TELEGRAM_BOT_TOKEN=123456:replace_with_real_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_CHANNEL_ID=@your_channel_or_chat_id
# Optional: reserved for future admin/bot commands allow-list.
TELEGRAM_ALLOWED_CHAT_IDS=

# FastAPI application
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=replace_with_random_secret
WEBHOOK_API_TOKEN=replace_with_random_webhook_token
APP_LOG_LEVEL=info
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# true applies Alembic migrations automatically at app startup for local MVP; set false to run migrations manually.
AUTO_MIGRATE=true

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace_with_32_plus_character_key
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n

# Optional Adminer
ADMINER_PORT=8080

# General
TZ=UTC
